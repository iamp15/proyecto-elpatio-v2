PORT=3001

# URI de MongoDB Atlas (la misma que usa el api-gateway)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/el_patio_db

# Debe coincidir exactamente con el JWT_SECRET del api-gateway
JWT_SECRET=change-me-in-production

# URL del api-gateway (usado si se necesitan llamadas HTTP internas)
API_GATEWAY_URL=http://localhost:3000

# Orígenes permitidos por CORS (separados por coma)
# CORS_ORIGIN=http://localhost:5173,http://localhost:5174,https://tu-webapp.vercel.app
